        "jsonOutput": "{\n  \"ODOO_URL\": \"https://188.166.189.244.nip.io\",\n  \"ODOO_DB\": \"odoo\",\n  \"ODOO_USER\": \"admin\",\n  \"ODOO_API_KEY\": \"YOUR_API_KEY_HERE\",\n  \"WEBSITE_URL\": \"https://coworkspace-main.vercel.app\"\n}",
        "options": {}
