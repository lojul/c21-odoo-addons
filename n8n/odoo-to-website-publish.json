    {
      "parameters": {
        "jsCode": "// Transform Odoo coworking property to website listing format\nconst odoo = $input.first().json;\nconst config = odoo._config;\n\n// Map district codes to Chinese names\nconst districtMap = {\n  'central': '中環',\n  'admiralty': '金鐘',\n  'wan_chai': '灣仔',\n  'causeway_bay': '銅鑼灣',\n  'north_point': '北角',\n  'quarry_bay': '鰂魚涌',\n  'taikoo': '太古',\n  'wong_chuk_hang': '黃竹坑',\n  'sheung_wan': '上環',\n  'tsim_sha_tsui': '尖沙咀',\n  'jordan': '佐敦',\n  'mong_kok': '旺角',\n  'kowloon_bay': '九龍灣',\n  'kwun_tong': '觀塘',\n  'san_po_kong': '新蒲崗',\n  'kwai_chung': '葵涌',\n  'tsuen_wan': '荃灣',\n  'sha_tin': '沙田',\n  'fo_tan': '火炭',\n  'tuen_mun': '屯門',\n  'yuen_long': '元朗',\n  'other': '其他'\n};\n\nconst listing = {\n  id: `odoo-${odoo.id}`,\n  refCode: odoo.ref_code || '',\n  name: odoo.name || '',\n  nameCn: odoo.name_cn || odoo.name || '',\n  district: districtMap[odoo.district] || odoo.district || '',\n  building: odoo.building_name || '',\n  address: odoo.address || '',\n  floor: odoo.floor || '',\n  operator: '',\n  capacity: odoo.capacity || 0,\n  availableCapacity: odoo.available_capacity || 0,\n  size: odoo.size || 0,\n  hotDeskPrice: odoo.hot_desk_price || 0,\n  dedicatedDeskPrice: odoo.dedicated_desk_price || 0,\n  officePrice: odoo.office_price || 0,\n  description: odoo.description || '',\n  descriptionCn: odoo.description_cn || '',\n  images: [],\n  amenities: [],\n  status: 'approved',\n  importedBy: 'odoo-n8n',\n  odooId: odoo.id,\n  _config: config\n};\n\nreturn [{ json: listing }];"
      },
      "id": "transform-coworking",
      "name": "Transform Coworking",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, -100]
    },
    {
      "parameters": {
        "jsCode": "// Transform Odoo leasing property to website format\nconst odoo = $input.first().json;\nconst config = odoo._config;\n\n// Map district codes to Chinese names\nconst districtMap = {\n  'central': '中環',\n  'admiralty': '金鐘',\n  'wan_chai': '灣仔',\n  'causeway_bay': '銅鑼灣',\n  'north_point': '北角',\n  'quarry_bay': '鰂魚涌',\n  'taikoo': '太古',\n  'wong_chuk_hang': '黃竹坑',\n  'sheung_wan': '上環',\n  'tsim_sha_tsui': '尖沙咀',\n  'jordan': '佐敦',\n  'mong_kok': '旺角',\n  'kowloon_bay': '九龍灣',\n  'kwun_tong': '觀塘',\n  'san_po_kong': '新蒲崗',\n  'kwai_chung': '葵涌',\n  'tsuen_wan': '荃灣',\n  'sha_tin': '沙田',\n  'fo_tan': '火炭',\n  'tuen_mun': '屯門',\n  'yuen_long': '元朗',\n  'other': '其他'\n};\n\n// Map property type\nconst propertyTypeMap = {\n  'office': 'office',\n  'retail': 'retail',\n  'industrial': 'industrial'\n};\n\n// Map building grade\nconst gradeMap = {\n  'grade_a': 'A',\n  'grade_b': 'B',\n  'grade_c': 'C'\n};\n\n// Build address from components\nconst addressParts = [\n  odoo.building_name,\n  odoo.address,\n  odoo.floor,\n  odoo.unit\n].filter(Boolean);\n\nconst leasing = {\n  id: `odoo-${odoo.id}`,\n  refCode: odoo.ref_code || '',\n  name: odoo.name || '',\n  nameCn: odoo.name_cn || odoo.name || '',\n  address: addressParts.join(', '),\n  district: districtMap[odoo.district] || odoo.district || '',\n  propertyType: propertyTypeMap[odoo.property_type] || 'office',\n  buildingGrade: gradeMap[odoo.building_grade] || undefined,\n  businessType: odoo.business_type || undefined,\n  grossArea: odoo.gross_area || 0,\n  netArea: odoo.net_area || 0,\n  pricePerSqft: odoo.rent_per_sqft || 0,\n  monthlyRent: odoo.asking_rent || 0,\n  agentName: '',\n  agentPhone: '',\n  agentEmail: '',\n  images: [],\n  amenities: [],\n  availableFrom: odoo.available_from || new Date().toISOString().split('T')[0],\n  leaseTerms: odoo.lease_terms || '',\n  description: odoo.description || '',\n  status: 'approved',\n  importedBy: 'odoo-n8n',\n  odooId: odoo.id,\n  _config: config\n};\n\nreturn [{ json: leasing }];"
      },
