    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.ODOO_URL }}/xmlrpc/2/common",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/xml",
        "body": "=<?xml version=\"1.0\"?>\n<methodCall>\n  <methodName>authenticate</methodName>\n  <params>\n    <param><value><string>{{ $json.ODOO_DB }}</string></value></param>\n    <param><value><string>{{ $json.ODOO_USER }}</string></value></param>\n    <param><value><string>{{ $json.ODOO_API_KEY }}</string></value></param>\n    <param><value><struct></struct></value></param>\n  </params>\n</methodCall>",
        "options": {}
      },
      "id": "odoo-auth",
      "name": "Odoo Authenticate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "// Parse XML-RPC response to get UID\nconst xmlResponse = $input.first().json.data;\nconst uidMatch = xmlResponse.match(/<int>(\\d+)<\\/int>/);\n\nif (!uidMatch) {\n  throw new Error('Authentication failed - no UID returned');\n}\n\nconst uid = parseInt(uidMatch[1]);\n\nif (uid === 0) {\n  throw new Error('Authentication failed - invalid credentials');\n}\n\n// Get config from earlier node\nconst config = $('Config').first().json;\n\nreturn [{ json: { uid, ...config } }];"
      },
      "id": "parse-auth",
      "name": "Parse Auth Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.ODOO_URL }}/xmlrpc/2/object",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/xml",
        "body": "=<?xml version=\"1.0\"?>\n<methodCall>\n  <methodName>execute_kw</methodName>\n  <params>\n    <param><value><string>{{ $json.ODOO_DB }}</string></value></param>\n    <param><value><int>{{ $json.uid }}</int></value></param>\n    <param><value><string>{{ $json.ODOO_API_KEY }}</string></value></param>\n    <param><value><string>c21.property.listing</string></value></param>\n    <param><value><string>search_read</string></value></param>\n    <param><value><array><data>\n      <value><array><data>\n        <value><array><data>\n          <value><string>approval_status</string></value>\n          <value><string>=</string></value>\n          <value><string>ready</string></value>\n        </data></array></value>\n      </data></array></value>\n    </data></array></value></param>\n    <param><value><struct>\n      <member>\n        <name>fields</name>\n        <value><array><data>\n          <value><string>id</string></value>\n          <value><string>ref_code</string></value>\n          <value><string>name</string></value>\n          <value><string>name_cn</string></value>\n          <value><string>listing_type</string></value>\n          <value><string>district</string></value>\n          <value><string>building_name</string></value>\n          <value><string>address</string></value>\n          <value><string>floor</string></value>\n          <value><string>unit</string></value>\n          <value><string>state</string></value>\n          <value><string>property_type</string></value>\n          <value><string>building_grade</string></value>\n          <value><string>business_type</string></value>\n          <value><string>gross_area</string></value>\n          <value><string>net_area</string></value>\n          <value><string>asking_rent</string></value>\n          <value><string>rent_per_sqft</string></value>\n          <value><string>lease_terms</string></value>\n          <value><string>available_from</string></value>\n          <value><string>description</string></value>\n          <value><string>description_cn</string></value>\n          <value><string>operator_id</string></value>\n          <value><string>capacity</string></value>\n          <value><string>available_capacity</string></value>\n          <value><string>size</string></value>\n          <value><string>hot_desk_price</string></value>\n          <value><string>dedicated_desk_price</string></value>\n          <value><string>office_price</string></value>\n        </data></array></value>\n      </member>\n    </struct></value></param>\n  </params>\n</methodCall>",
        "options": {}
      },
      "id": "odoo-search-ready",
      "name": "Search Ready Properties",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0]
    },
    {
      "parameters": {
        "jsCode": "// Parse XML-RPC response to extract property records\nconst xmlResponse = $input.first().json.data;\n\n// Get config from earlier node\nconst config = $('Parse Auth Response').first().json;\n\n// Simple XML parsing for Odoo response\nconst records = [];\n\n// Match all <struct> blocks that contain property data\nconst structRegex = /<struct>([\\s\\S]*?)<\\/struct>/g;\nlet structMatch;\n\nwhile ((structMatch = structRegex.exec(xmlResponse)) !== null) {\n  const structContent = structMatch[1];\n  const record = {};\n  \n  // Extract each member\n  const memberRegex = /<member>\\s*<name>([^<]+)<\\/name>\\s*<value>(?:<([^>]+)>([^<]*)<\\/\\2>|<([^\\/>]+)\\/>)/g;\n  let memberMatch;\n  \n  while ((memberMatch = memberRegex.exec(structContent)) !== null) {\n    const name = memberMatch[1];\n    const type = memberMatch[2] || memberMatch[4];\n    let value = memberMatch[3] || '';\n    \n    // Convert based on type\n    if (type === 'int' || type === 'i4') {\n      value = parseInt(value) || 0;\n    } else if (type === 'double') {\n      value = parseFloat(value) || 0;\n    } else if (type === 'boolean') {\n      value = value === '1';\n    } else if (type === 'nil') {\n      value = null;\n    }\n    \n    record[name] = value;\n  }\n  \n  // Only include records with an id field (actual property records)\n  if (record.id && typeof record.id === 'number') {\n    records.push(record);\n  }\n}\n\nif (records.length === 0) {\n  // Return empty to stop workflow gracefully\n  return [];\n}\n\n// Add config to each record for downstream use\nreturn records.map(r => ({ \n  json: { \n    ...r, \n    _config: {\n      ODOO_URL: config.ODOO_URL,\n      ODOO_DB: config.ODOO_DB,\n      ODOO_API_KEY: config.ODOO_API_KEY,\n      WEBSITE_URL: config.WEBSITE_URL,\n      uid: config.uid\n    }\n  } \n}));"
      },
      "id": "parse-properties",
      "name": "Parse Properties",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 0]
    },
