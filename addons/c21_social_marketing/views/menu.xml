<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main Menu -->
    <menuitem id="menu_social_marketing_root"
              name="C21 Social Marketing"
              web_icon="c21_social_marketing,static/description/icon.png"
              sequence="90"/>

    <!-- Posts Submenu -->
    <menuitem id="menu_social_posts"
              name="Posts"
              parent="menu_social_marketing_root"
              action="action_social_post"
              sequence="10"/>

    <!-- News Submenu -->
    <menuitem id="menu_social_news"
              name="News"
              parent="menu_social_marketing_root"
              action="action_social_news"
              sequence="20"/>

    <!-- Cleanup Action -->
    <record id="action_cleanup_news_menu" model="ir.actions.server">
        <field name="name">清理舊新聞</field>
        <field name="model_id" ref="model_c21_social_feed"/>
        <field name="state">code</field>
        <field name="code">action = model.action_cleanup_news()</field>
    </record>

    <menuitem id="menu_cleanup_news"
              name="清理舊新聞"
              parent="menu_social_marketing_root"
              action="action_cleanup_news_menu"
              sequence="25"/>

    <!-- Configuration Menu -->
    <menuitem id="menu_social_config"
              name="Configuration"
              parent="menu_social_marketing_root"
              sequence="100"
              groups="base.group_system"/>

    <menuitem id="menu_social_channels"
              name="Channels"
              parent="menu_social_config"
              action="action_social_channel"
              sequence="10"/>

    <menuitem id="menu_social_feeds"
              name="RSS Feeds"
              parent="menu_social_config"
              action="action_social_feed"
              sequence="20"/>

    <menuitem id="menu_social_settings"
              name="API Settings"
              parent="menu_social_config"
              action="action_social_marketing_config"
              sequence="30"/>

</odoo>
