<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Settings Form View -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.c21.social</field>
        <field name="model">res.config.settings</field>
        <field name="priority">50</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="C21 Social Marketing" string="C21 Social Marketing" name="c21_social_marketing" logo="/c21_social_marketing/static/description/icon.png">
                    <block title="API Settings" name="api_settings">
                        <setting string="OpenRouter API Key" help="For AI-generated post content (DeepSeek)">
                            <field name="social_openrouter_api_key" password="True"/>
                        </setting>
                        <setting string="Buffer API Token" help="For posting to social media">
                            <field name="social_buffer_api_token" password="True"/>
                        </setting>
                        <setting string="imgbb API Key" help="For image hosting">
                            <field name="social_imgbb_api_key" password="True"/>
                        </setting>
                    </block>
                    <block title="AI Settings" name="ai_settings">
                        <setting string="AI Model" help="OpenRouter model ID">
                            <field name="social_ai_model" placeholder="deepseek/deepseek-chat"/>
                        </setting>
                    </block>
                    <block title="Automation Settings" name="automation_settings">
                        <setting string="Auto Approve" help="Auto-approve generated posts">
                            <field name="social_auto_approve"/>
                        </setting>
                        <setting string="Auto Send" help="Auto-send to Buffer after approval">
                            <field name="social_auto_send"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Settings Action -->
    <record id="action_social_marketing_config" model="ir.actions.act_window">
        <field name="name">C21 Social Marketing Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'c21_social_marketing', 'bin_size': False}</field>
    </record>

</odoo>
