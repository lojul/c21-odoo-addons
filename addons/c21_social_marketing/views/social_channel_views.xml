<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Channel Form View -->
    <record id="view_social_channel_form" model="ir.ui.view">
        <field name="name">c21.social.channel.form</field>
        <field name="model">c21.social.channel</field>
        <field name="arch" type="xml">
            <form string="Social Media Channel">
                <sheet>
                    <group>
                        <group string="Basic Info">
                            <field name="name"/>
                            <field name="platform"/>
                            <field name="buffer_channel_id"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Settings">
                            <field name="include_image"/>
                            <field name="hashtags" placeholder="Platform-specific hashtags"/>
                        </group>
                    </group>
                    <group string="Statistics">
                        <field name="last_post_time" readonly="1"/>
                        <field name="post_count" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Channel List View -->
    <record id="view_social_channel_list" model="ir.ui.view">
        <field name="name">c21.social.channel.list</field>
        <field name="model">c21.social.channel</field>
        <field name="arch" type="xml">
            <list string="Social Media Channels" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="platform"/>
                <field name="buffer_channel_id"/>
                <field name="include_image"/>
                <field name="last_post_time"/>
                <field name="post_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Channel Action -->
    <record id="action_social_channel" model="ir.actions.act_window">
        <field name="name">Channels</field>
        <field name="res_model">c21.social.channel</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
