<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Post Form View -->
    <record id="view_social_post_form" model="ir.ui.view">
        <field name="name">c21.social.post.form</field>
        <field name="model">c21.social.post</field>
        <field name="arch" type="xml">
            <form string="Social Media Post">
                <header>
                    <button name="action_generate_captions" type="object" string="AI Generate Content"
                            class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_submit_for_approval" type="object" string="Submit for Approval"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-success" invisible="state != 'pending'"/>
                    <button name="action_reject" type="object" string="Reject"
                            class="btn-secondary" invisible="state != 'pending'"/>
                    <button name="action_send_to_buffer" type="object" string="Send to Buffer"
                            class="btn-primary" invisible="state not in ('approved',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,scheduled,posted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <group>
                        <group string="Content">
                            <field name="headline_zh" placeholder="Chinese headline (max 20 chars)"/>
                            <field name="data_point" placeholder="Key data point"/>
                            <field name="district"/>
                            <field name="source"/>
                            <field name="background_color" widget="radio"/>
                        </group>
                        <group string="Image Preview">
                            <field name="image" widget="image" options="{'size': [300, 375]}"/>
                            <button name="action_generate_image" type="object"
                                    string="Regenerate Image" class="btn-outline-secondary"
                                    icon="fa-refresh" invisible="not headline_zh"/>
                            <field name="image_url" readonly="1" string="Image URL"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Instagram" name="instagram">
                            <field name="ig_caption" placeholder="Instagram caption (max 100 chars)"/>
                        </page>
                        <page string="Facebook" name="facebook">
                            <field name="fb_caption" placeholder="Facebook caption (max 200 chars)"/>
                        </page>
                        <page string="Threads" name="threads">
                            <field name="threads_caption" placeholder="Threads caption"/>
                        </page>
                        <page string="Publish Settings" name="settings">
                            <group>
                                <field name="channel_ids" widget="many2many_checkboxes"/>
                                <field name="scheduled_time"/>
                                <field name="posted_time" readonly="1"/>
                                <field name="is_auto_generated" readonly="1"/>
                            </group>
                        </page>
                        <page string="Related News" name="news">
                            <field name="news_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="source"/>
                                    <field name="fetch_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Technical Info" name="technical" groups="base.group_system">
                            <group>
                                <field name="buffer_response" readonly="1"/>
                                <field name="error_message" readonly="1" invisible="not error_message"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Post List View -->
    <record id="view_social_post_list" model="ir.ui.view">
        <field name="name">c21.social.post.list</field>
        <field name="model">c21.social.post</field>
        <field name="arch" type="xml">
            <list string="Social Media Posts" default_order="create_date desc">
                <field name="create_date" string="Created"/>
                <field name="headline_zh"/>
                <field name="district"/>
                <field name="source"/>
                <field name="background_color"/>
                <field name="channel_ids" widget="many2many_tags"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'"
                       decoration-warning="state == 'pending'"
                       decoration-success="state in ('approved', 'scheduled', 'posted')"
                       decoration-danger="state == 'failed'"/>
                <field name="is_auto_generated" string="Auto"/>
            </list>
        </field>
    </record>

    <!-- Post Kanban View -->
    <record id="view_social_post_kanban" model="ir.ui.view">
        <field name="name">c21.social.post.kanban</field>
        <field name="model">c21.social.post</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="image"/>
                <field name="headline_zh"/>
                <field name="channel_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image" t-if="record.image.raw_value">
                            <field name="image" widget="image" options="{'preview_image': 'image'}"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong class="o_kanban_record_title">
                                <field name="headline_zh"/>
                            </strong>
                            <div class="o_kanban_record_subtitle">
                                <field name="district"/> | <field name="source"/>
                            </div>
                            <div class="mt-2">
                                <field name="channel_ids" widget="many2many_tags"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Post Search View -->
    <record id="view_social_post_search" model="ir.ui.view">
        <field name="name">c21.social.post.search</field>
        <field name="model">c21.social.post</field>
        <field name="arch" type="xml">
            <search string="Search Posts">
                <field name="headline_zh"/>
                <field name="district"/>
                <field name="source"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter string="Auto Generated" name="auto" domain="[('is_auto_generated', '=', True)]"/>
            </search>
        </field>
    </record>

    <!-- Post Action -->
    <record id="action_social_post" model="ir.actions.act_window">
        <field name="name">Posts</field>
        <field name="res_model">c21.social.post</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first social media post
            </p>
            <p>
                The system will automatically fetch news and generate post content.
            </p>
        </field>
    </record>

</odoo>
