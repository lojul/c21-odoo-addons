<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Feed Form View -->
    <record id="view_social_feed_form" model="ir.ui.view">
        <field name="name">c21.social.feed.form</field>
        <field name="model">c21.social.feed</field>
        <field name="arch" type="xml">
            <form string="RSS Feed">
                <header>
                    <button name="action_fetch_now" type="object" string="Fetch Now" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Basic Info">
                            <field name="name"/>
                            <field name="url" widget="url"/>
                            <field name="language"/>
                            <field name="priority"/>
                            <field name="active"/>
                        </group>
                        <group string="Statistics">
                            <field name="last_fetch" readonly="1"/>
                            <field name="news_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Feed List View -->
    <record id="view_social_feed_list" model="ir.ui.view">
        <field name="name">c21.social.feed.list</field>
        <field name="model">c21.social.feed</field>
        <field name="arch" type="xml">
            <list string="RSS Feeds">
                <field name="priority"/>
                <field name="name"/>
                <field name="last_fetch"/>
                <field name="news_count"/>
                <field name="active"/>
                <button name="action_fetch_now" type="object" string="Fetch" icon="fa-download" class="btn-link"/>
            </list>
        </field>
    </record>

    <!-- Feed Action -->
    <record id="action_social_feed" model="ir.actions.act_window">
        <field name="name">RSS Feeds</field>
        <field name="res_model">c21.social.feed</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- News Form View -->
    <record id="view_social_news_form" model="ir.ui.view">
        <field name="name">c21.social.news.form</field>
        <field name="model">c21.social.news</field>
        <field name="arch" type="xml">
            <form string="News">
                <header>
                    <button name="action_create_post" type="object" string="Generate Post" class="btn-primary" invisible="used"/>
                    <field name="used" widget="boolean_toggle" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="News Info">
                            <field name="source" readonly="1"/>
                            <field name="feed_id" readonly="1"/>
                            <field name="fetch_date" readonly="1"/>
                            <field name="publish_date" readonly="1"/>
                            <field name="url" widget="url" readonly="1"/>
                        </group>
                        <group string="Relevance">
                            <field name="is_property_news" readonly="1"/>
                            <field name="relevance_score" readonly="1"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Related Posts" invisible="not post_ids">
                        <field name="post_ids" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- News List View -->
    <record id="view_social_news_list" model="ir.ui.view">
        <field name="name">c21.social.news.list</field>
        <field name="model">c21.social.news</field>
        <field name="arch" type="xml">
            <list string="News" default_order="fetch_date desc">
                <field name="fetch_date"/>
                <field name="name"/>
                <field name="source"/>
                <field name="is_property_news"/>
                <field name="relevance_score"/>
                <field name="used"/>
                <field name="url" widget="url"/>
            </list>
        </field>
    </record>

    <!-- News Search View -->
    <record id="view_social_news_search" model="ir.ui.view">
        <field name="name">c21.social.news.search</field>
        <field name="model">c21.social.news</field>
        <field name="arch" type="xml">
            <search string="Search News">
                <field name="name"/>
                <field name="source"/>
                <filter string="Property News" name="property" domain="[('is_property_news', '=', True)]"/>
                <filter string="Unused" name="unused" domain="[('used', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- News Action -->
    <record id="action_social_news" model="ir.actions.act_window">
        <field name="name">News</field>
        <field name="res_model">c21.social.news</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_property': 1}</field>
    </record>

</odoo>
