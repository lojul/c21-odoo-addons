<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Default RSS Feeds -->
        <record id="feed_google_news_hk" model="c21.social.feed">
            <field name="name">Google News 香港商業地產</field>
            <field name="url">https://news.google.com/rss/search?q=香港商業地產+OR+香港寫字樓+OR+香港商廈+OR+香港工廈&amp;hl=zh-TW&amp;gl=HK&amp;ceid=HK:zh-Hant</field>
            <field name="priority">1</field>
            <field name="language">zh</field>
            <field name="active">True</field>
        </record>

        <record id="feed_scmp_property" model="c21.social.feed">
            <field name="name">SCMP Property</field>
            <field name="url">https://www.scmp.com/rss/96/feed</field>
            <field name="priority">2</field>
            <field name="language">en</field>
            <field name="active">True</field>
        </record>

        <!-- Default Channels (user needs to update Buffer IDs) -->
        <record id="channel_instagram" model="c21.social.channel">
            <field name="name">Instagram c21net.hk</field>
            <field name="platform">instagram</field>
            <field name="buffer_channel_id">69ec2f5c031bfa423c3ed8a2</field>
            <field name="sequence">1</field>
            <field name="include_image">True</field>
            <field name="active">True</field>
        </record>

        <record id="channel_facebook" model="c21.social.channel">
            <field name="name">Facebook 世紀21卓越物業服務</field>
            <field name="platform">facebook</field>
            <field name="buffer_channel_id">69eb7d99031bfa423c3bb112</field>
            <field name="sequence">2</field>
            <field name="include_image">True</field>
            <field name="active">True</field>
        </record>

        <record id="channel_threads" model="c21.social.channel">
            <field name="name">Threads c21net.hk</field>
            <field name="platform">threads</field>
            <field name="buffer_channel_id">69ede9285c4c051afadf6bc5</field>
            <field name="sequence">3</field>
            <field name="include_image">True</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
