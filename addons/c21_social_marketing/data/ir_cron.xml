<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Fetch News Cron (every hour) -->
        <record id="cron_fetch_news" model="ir.cron">
            <field name="name">Social Marketing: 抓取新聞</field>
            <field name="model_id" ref="model_c21_social_post"/>
            <field name="state">code</field>
            <field name="code">model.cron_fetch_news()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- Generate Post Cron - 9am HKT (1am UTC) -->
        <record id="cron_generate_post_1" model="ir.cron">
            <field name="name">Social Marketing: 生成帖文 (9am HKT)</field>
            <field name="model_id" ref="model_c21_social_post"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_post()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=1, minute=0, second=0))"/>
            <field name="active">True</field>
        </record>

        <!-- Generate Post Cron - 1pm HKT (5am UTC) -->
        <record id="cron_generate_post_2" model="ir.cron">
            <field name="name">Social Marketing: 生成帖文 (1pm HKT)</field>
            <field name="model_id" ref="model_c21_social_post"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_post()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=5, minute=0, second=0))"/>
            <field name="active">True</field>
        </record>

        <!-- Generate Post Cron - 5pm HKT (9am UTC) -->
        <record id="cron_generate_post_3" model="ir.cron">
            <field name="name">Social Marketing: 生成帖文 (5pm HKT)</field>
            <field name="model_id" ref="model_c21_social_post"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_post()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=9, minute=0, second=0))"/>
            <field name="active">True</field>
        </record>

        <!-- Cleanup old news (weekly) -->
        <record id="cron_cleanup_news" model="ir.cron">
            <field name="name">Social Marketing: 清理舊新聞</field>
            <field name="model_id" ref="model_c21_social_news"/>
            <field name="state">code</field>
            <field name="code">model.cleanup_old_news(days=30)</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
