<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default System Prompt -->
        <record id="config_system_prompt" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.system_prompt</field>
            <field name="value">You are C21Net AI Assistant, the internal assistant for Century 21 commercial real estate company in Hong Kong.

IMPORTANT RESTRICTIONS:
- You ONLY answer questions related to C21 business operations
- You MUST refuse to help with anything unrelated to real estate, properties, CRM, or company business
- If asked about coding, recipes, games, general knowledge, homework, or ANY off-topic subjects, politely decline and redirect to business topics

Your capabilities:
1. Search property listings (offices, retail, industrial spaces, coworking)
2. Query CRM leads and contacts
3. Search property documents and particulars
4. Answer questions about C21 business operations and real estate

When refusing off-topic requests, say:
"抱歉，我只能回答與 C21 業務相關的問題。請問有什麼物業或客戶相關的問題我可以幫到你？"

Guidelines:
- Respond in the same language as the user (English or Chinese)
- When showing property results, include key details: name, address, area, rent
- For CRM queries, respect user access permissions
- Be concise and professional
- Stay focused on business topics only

Current date: {current_date}
User: {user_name}
Company: {company_name}</field>
        </record>

        <!-- Default Welcome Message -->
        <record id="config_welcome_message" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.welcome_message</field>
            <field name="value">Hello! I am the C21 AI Assistant. I can help you:
- Search property listings
- Query CRM leads and contacts
- Search property documents
- Answer general questions

How can I help you today?</field>
        </record>

        <!-- Default Provider -->
        <record id="config_provider" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.provider</field>
            <field name="value">openrouter</field>
        </record>

        <!-- Default Model -->
        <record id="config_model" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.model</field>
            <field name="value">meta-llama/llama-3.3-70b-instruct</field>
        </record>

        <!-- Default Temperature -->
        <record id="config_temperature" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.temperature</field>
            <field name="value">0.7</field>
        </record>

        <!-- Default Max Tokens -->
        <record id="config_max_tokens" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.max_tokens</field>
            <field name="value">2048</field>
        </record>

        <!-- Feature Toggles - Enabled by default -->
        <record id="config_property_search" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.property_search_enabled</field>
            <field name="value">True</field>
        </record>

        <record id="config_crm_search" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.crm_search_enabled</field>
            <field name="value">True</field>
        </record>

        <record id="config_rag_enabled" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.rag_enabled</field>
            <field name="value">True</field>
        </record>

        <record id="config_general_qa" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.general_qa_enabled</field>
            <field name="value">True</field>
        </record>

        <!-- Search Settings -->
        <record id="config_max_search_results" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.max_search_results</field>
            <field name="value">10</field>
        </record>

        <record id="config_session_timeout" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.session_timeout</field>
            <field name="value">30</field>
        </record>

        <!-- Default n8n RAG endpoint -->
        <record id="config_rag_endpoint" model="ir.config_parameter">
            <field name="key">c21_ai_assistant.rag_endpoint</field>
            <field name="value">https://c21net.app.n8n.cloud/webhook/f4703658-8e72-4971-b5b1-5df68c772ae2</field>
        </record>
    </data>
</odoo>
