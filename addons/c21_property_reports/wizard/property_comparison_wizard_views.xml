<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_property_comparison_wizard_form" model="ir.ui.view">
        <field name="name">c21.property.comparison.wizard.form</field>
        <field name="model">c21.property.comparison.wizard</field>
        <field name="arch" type="xml">
            <form string="Property Comparison Report">
                <group>
                    <field name="property_ids" widget="many2many_tags"
                           options="{'no_create': True}"
                           domain="[]"/>
                </group>
                <div class="text-muted">
                    Select 2-5 properties to compare. The report will show a side-by-side comparison of key metrics.
                </div>
                <footer>
                    <button name="action_generate_report" string="Generate Report" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_property_comparison_wizard" model="ir.actions.act_window">
        <field name="name">Compare Properties</field>
        <field name="res_model">c21.property.comparison.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="c21_property_listing.model_c21_property_listing"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
