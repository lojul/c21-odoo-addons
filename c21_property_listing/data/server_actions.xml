    <!-- Mass Update Server Actions for Property Listings -->

    <!-- Publish Status Actions -->
    <record id="action_mass_set_draft" model="ir.actions.server">
        <field name="name">Set: Draft</field>
        <field name="model_id" ref="model_c21_property_listing"/>
        <field name="binding_model_id" ref="model_c21_property_listing"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
