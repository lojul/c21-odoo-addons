<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Property Image Form View -->
    <record id="c21_property_image_view_form" model="ir.ui.view">
        <field name="name">c21.property.image.form</field>
        <field name="model">c21.property.image</field>
        <field name="arch" type="xml">
            <form string="Image" class="c21_property_form_aligned">
                <sheet>
                    <group>
                        <group>
                            <field name="property_id" string="Property / 物業:"/>
                            <field name="name" string="Description / 描述:" placeholder="Image description..."/>
                            <field name="is_cover" string="Cover Image? / 封面圖?"/>
                            <field name="image" widget="image" options="{'size': [0, 200]}"/>
                        </group>
                        <group>
                            <button name="action_download_from_url" type="object"
                                    string="Download" class="btn-primary"
                                    invisible="not image_url"
                                    icon="fa-download"/>
                        </group>
                    </group>
                    <field name="sequence" invisible="1"/>
                    <field name="image_url" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Property Image Tree View -->
    <record id="c21_property_image_view_tree" model="ir.ui.view">
        <field name="name">c21.property.image.tree</field>
        <field name="model">c21.property.image</field>
        <field name="arch" type="xml">
            <list string="Property Images">
                <field name="is_cover" string="Cover"/>
                <field name="image_small" widget="image" options="{'size': [48, 48]}"/>
                <field name="name" string="Description"/>
                <field name="property_id"/>
            </list>
        </field>
    </record>

    <!-- Property Contact Form View -->
    <record id="c21_property_contact_view_form" model="ir.ui.view">
        <field name="name">c21.property.contact.form</field>
        <field name="model">c21.property.contact</field>
        <field name="arch" type="xml">
            <form string="Contact" class="c21_property_form_aligned">
                <sheet>
                    <group>
                        <group>
                            <field name="property_id" string="Property / 物業:"/>
                            <field name="partner_id" string="Name / 姓名:"/>
                            <field name="role" string="Title / 職稱:"/>
                            <field name="phone" string="Phone / 電話:"/>
                            <field name="email" string="Email / 電郵:"/>
                        </group>
                        <group>
                            <field name="is_primary" string="Primary Contact? / 主要聯絡人?"/>
                            <field name="notes" string="Note / 備註:" placeholder="Additional notes..."/>
                        </group>
                    </group>
                    <field name="sequence" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
