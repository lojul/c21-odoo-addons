<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Business Type Tree View -->
    <record id="c21_business_type_view_tree" model="ir.ui.view">
        <field name="name">c21.business.type.tree</field>
        <field name="model">c21.business.type</field>
        <field name="arch" type="xml">
            <list string="Business Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="name_cn"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Business Type Form View -->
    <record id="c21_business_type_view_form" model="ir.ui.view">
        <field name="name">c21.business.type.form</field>
        <field name="model">c21.business.type</field>
        <field name="arch" type="xml">
            <form string="Business Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="name_cn"/>
                        </group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Business Type Action -->
    <record id="c21_business_type_action" model="ir.actions.act_window">
        <field name="name">Business Types / 業務類型</field>
        <field name="res_model">c21.business.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
