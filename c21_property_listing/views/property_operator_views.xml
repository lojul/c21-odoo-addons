<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Operator Form View (extends res.partner) -->
    <record id="c21_property_operator_view_form" model="ir.ui.view">
        <field name="name">c21.property.operator.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="company_type" position="attributes">
                <attribute name="invisible">is_property_operator</attribute>
            </field>
            <page name="sales_purchases" position="attributes">
                <attribute name="invisible">is_property_operator</attribute>
            </page>
            <field name="category_id" position="after">
                <field name="is_property_operator"/>
                <field name="operator_logo_url" invisible="not is_property_operator"/>
            </field>
            <div name="button_box" position="inside">
                <button name="%(c21_property_listing.c21_property_listing_action)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-building"
                        invisible="not is_property_operator">
                    <field name="property_count" widget="statinfo" string="Properties"/>
                </button>
            </div>
        </field>
    </record>

    <!-- Operator Tree View -->
    <record id="c21_property_operator_view_tree" model="ir.ui.view">
        <field name="name">c21.property.operator.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Property Operators">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="property_count"/>
            </list>
        </field>
    </record>

    <!-- Operator Kanban View -->
    <record id="c21_property_operator_view_kanban" model="ir.ui.view">
        <field name="name">c21.property.operator.kanban</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="property_count"/>
                <field name="operator_logo_url"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div t-if="record.email.value">
                                    <i class="fa fa-envelope me-1"/> <field name="email"/>
                                </div>
                                <div t-if="record.phone.value">
                                    <i class="fa fa-phone me-1"/> <field name="phone"/>
                                </div>
                                <div class="mt-2">
                                    <span class="badge text-bg-primary">
                                        <field name="property_count"/> Properties
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Operator Search View -->
    <record id="c21_property_operator_view_search" model="ir.ui.view">
        <field name="name">c21.property.operator.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Search Operators">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
            </search>
        </field>
    </record>

    <!-- Operator Action -->
    <record id="c21_property_operator_action" model="ir.actions.act_window">
        <field name="name">Operators</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_property_operator', '=', True), ('is_company', '=', True)]</field>
        <field name="context">{
            'default_is_property_operator': True,
            'default_is_company': True,
            'default_company_type': 'company'
        }</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('c21_property_operator_view_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('c21_property_operator_view_tree')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first co-working operator
            </p>
            <p>
                Add operators like WeWork, Compass Offices, etc.
            </p>
        </field>
    </record>
</odoo>
