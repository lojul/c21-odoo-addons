<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="c21_res_country_view_tree_inherit" model="ir.ui.view">
        <field name="name">c21.res.country.tree.inherit</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_tree"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="c21_allowed_for_address" optional="show"/>
            </field>
        </field>
    </record>

    <record id="c21_res_country_view_form_inherit" model="ir.ui.view">
        <field name="name">c21.res.country.form.inherit</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_form"/>
        <field name="arch" type="xml">
            <field name="address_format" position="after">
                <field name="c21_allowed_for_address"/>
            </field>
        </field>
    </record>
</odoo>
