<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="c21_property_listing_view_form" model="ir.ui.view">
        <field name="name">c21.property.listing.form</field>
        <field name="model">c21.property.listing</field>
        <field name="arch" type="xml">
            <form string="Property Listing" class="c21_property_form_aligned">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_images" type="object"
                                class="oe_stat_button" icon="fa-image">
                            <field name="image_count" widget="statinfo" string="Images"/>
                        </button>
                        <button name="action_view_contacts" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="contact_count" widget="statinfo" string="Contacts"/>
                        </button>
                    </div>
                    <!-- Overview Section -->
                    <separator string="Overview"/>
                    <group>
                        <group>
                            <field name="name" string="English Name / 英文名稱"/>
                            <field name="name_cn" string="Chinese Name / 中文名稱"/>
                            <field name="ref_code"/>
                            <field name="listing_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="district"/>
                            <field name="approval_status" string="Publish / 發佈"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <!-- Location Section -->
                    <separator string="Location"/>
                    <group>
                        <group>
                            <field name="building_name"/>
                            <field name="floor"/>
                            <field name="unit"/>
                        </group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" placeholder="Full address..."/>
                    </group>

                    <!-- Co-working Details Section -->
                    <separator string="Co-working Details" invisible="listing_type != 'coworking'"/>
                    <group invisible="listing_type != 'coworking'">
                        <group>
                            <field name="operator_id"/>
                            <field name="size"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="available_capacity"/>
                        </group>
                    </group>
                    <group string="Pricing (HKD/month)" invisible="listing_type != 'coworking'">
                        <group>
                            <field name="hot_desk_price"/>
                            <field name="dedicated_desk_price"/>
                        </group>
                        <group>
                            <field name="office_price"/>
                        </group>
                    </group>

                    <!-- Leasing Details Section -->
                    <separator string="Leasing Details" invisible="listing_type != 'leasing'"/>
                    <group invisible="listing_type != 'leasing'">
                        <group>
                            <field name="property_type"/>
                            <field name="building_grade"/>
                            <field name="business_type"
                                   invisible="property_type != 'retail'"/>
                        </group>
                        <group>
                            <field name="year_built"/>
                            <field name="total_floors"/>
                        </group>
                    </group>
                    <group string="Area (sqft)" invisible="listing_type != 'leasing'">
                        <group>
                            <field name="gross_area"/>
                            <field name="net_area"/>
                        </group>
                        <group>
                            <field name="asking_rent"/>
                            <field name="rent_per_sqft"/>
                        </group>
                    </group>
                    <group invisible="listing_type != 'leasing'">
                        <field name="lease_terms"/>
                    </group>

                    <!-- Amenities Section -->
                    <separator string="Amenities"/>
                    <field name="amenity_ids" widget="many2many_tags"/>

                    <!-- Images Section -->
                    <separator string="Images"/>
                    <field name="image_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="is_cover"/>
                            <field name="image_small" widget="image" options="{'size': [64, 64]}"/>
                            <field name="name"/>
                            <field name="image_url" optional="hide" placeholder="Paste URL to auto-download"/>
                            <button name="action_download_from_url" type="object"
                                    icon="fa-download" title="Download from URL"
                                    invisible="not image_url"/>
                        </list>
                    </field>

                    <!-- Contacts Section -->
                    <separator string="Contacts"/>
                    <field name="contact_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="is_primary"/>
                            <field name="partner_id"/>
                            <field name="role"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="notes"/>
                        </list>
                    </field>

                    <!-- Description Section -->
                    <separator string="Description"/>
                    <group>
                        <field name="description" nolabel="1"
                               placeholder="Property description in English..."/>
                    </group>
                    <group>
                        <field name="description_cn" nolabel="1"
                               placeholder="Property description in Chinese..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="c21_property_listing_view_tree" model="ir.ui.view">
        <field name="name">c21.property.listing.tree</field>
        <field name="model">c21.property.listing</field>
        <field name="arch" type="xml">
            <list string="Property Listings" multi_edit="1" editable="bottom">
                <field name="name"/>
                <field name="listing_type" optional="show"/>
                <field name="district"/>
                <field name="operator_id" optional="show"/>
                <field name="capacity" optional="hide"/>
                <field name="ref_code" optional="hide"/>
                <field name="property_type" optional="hide"/>
                <field name="building_grade" optional="hide"/>
                <field name="net_area" optional="hide"/>
                <field name="display_price" optional="hide"/>
                <field name="state"/>
                <field name="approval_status"/>
                <button name="action_open_form" type="object" icon="fa-pencil" title="Edit"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="c21_property_listing_view_kanban" model="ir.ui.view">
        <field name="name">c21.property.listing.kanban</field>
        <field name="model">c21.property.listing</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="name"/>
                <field name="ref_code"/>
                <field name="listing_type"/>
                <field name="district"/>
                <field name="state"/>
                <field name="approval_status"/>
                <field name="display_price"/>
                <field name="operator_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="badge text-bg-secondary">
                                    <field name="ref_code"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong>District:</strong> <field name="district"/></div>
                                <div><strong>Type:</strong>
                                    <span t-if="record.listing_type.raw_value == 'coworking'" class="badge text-bg-info">Co-working</span>
                                    <span t-if="record.listing_type.raw_value == 'leasing'" class="badge text-bg-warning">Leasing</span>
                                </div>
                                <div><strong>Price:</strong> <field name="display_price"/></div>
                                <div t-if="record.operator_id.value">
                                    <strong>Operator:</strong> <field name="operator_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="c21_property_listing_view_search" model="ir.ui.view">
        <field name="name">c21.property.listing.search</field>
        <field name="model">c21.property.listing</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <field name="name"/>
                <field name="ref_code"/>
                <field name="building_name"/>
                <field name="district"/>
                <field name="operator_id"/>
                <separator/>
                <!-- Type Filters -->
                <filter name="filter_coworking" string="Co-working"
                        domain="[('listing_type', '=', 'coworking')]"/>
                <filter name="filter_leasing" string="Leasing"
                        domain="[('listing_type', '=', 'leasing')]"/>
                <separator/>
                <!-- Status Filters -->
                <filter name="filter_available" string="Available"
                        domain="[('state', '=', 'available')]"/>
                <filter name="filter_negotiation" string="Under Negotiation"
                        domain="[('state', '=', 'under_negotiation')]"/>
                <filter name="filter_leased" string="Leased"
                        domain="[('state', '=', 'leased')]"/>
                <separator/>
                <!-- Publish Status Filters -->
                <filter name="filter_draft" string="Draft"
                        domain="[('approval_status', '=', 'draft')]"/>
                <filter name="filter_ready" string="Ready to Publish"
                        domain="[('approval_status', '=', 'ready')]"/>
                <filter name="filter_published" string="Published"
                        domain="[('approval_status', '=', 'published')]"/>
                <separator/>
                <!-- Property Type Filters -->
                <filter name="filter_office" string="Office"
                        domain="[('property_type', '=', 'office')]"/>
                <filter name="filter_retail" string="Retail"
                        domain="[('property_type', '=', 'retail')]"/>
                <filter name="filter_industrial" string="Industrial"
                        domain="[('property_type', '=', 'industrial')]"/>
                <separator/>
                <!-- Grade Filters -->
                <filter name="filter_grade_a" string="Grade A"
                        domain="[('building_grade', '=', 'grade_a')]"/>
                <filter name="filter_grade_b" string="Grade B"
                        domain="[('building_grade', '=', 'grade_b')]"/>
                <separator/>
                <!-- Group By -->
                <group>
                    <filter name="group_district" string="District" context="{'group_by': 'district'}"/>
                    <filter name="group_listing_type" string="Listing Type" context="{'group_by': 'listing_type'}"/>
                    <filter name="group_property_type" string="Property Type" context="{'group_by': 'property_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_approval" string="Publish Status" context="{'group_by': 'approval_status'}"/>
                    <filter name="group_operator" string="Operator" context="{'group_by': 'operator_id'}"/>
                    <filter name="group_grade" string="Building Grade" context="{'group_by': 'building_grade'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="c21_property_listing_action_properties" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first property listing
            </p>
            <p>
                Add co-working spaces or leasing properties to manage your portfolio.
            </p>
        </field>
    </record>

    <record id="c21_property_listing_action" model="ir.actions.act_window">
        <field name="name">All Properties</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first property listing
            </p>
            <p>
                Add co-working spaces or leasing properties to manage your portfolio.
            </p>
        </field>
    </record>

    <record id="c21_property_listing_action_coworking" model="ir.actions.act_window">
        <field name="name">Co-working Spaces</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('listing_type', '=', 'coworking')]</field>
        <field name="context">{'default_listing_type': 'coworking'}</field>
    </record>

    <record id="c21_property_listing_action_leasing" model="ir.actions.act_window">
        <field name="name">Leasing Properties</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('listing_type', '=', 'leasing')]</field>
        <field name="context">{'default_listing_type': 'leasing'}</field>
    </record>

    <record id="c21_property_listing_action_ready" model="ir.actions.act_window">
        <field name="name">Ready to Publish</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('approval_status', '=', 'ready')]</field>
    </record>

    <record id="c21_property_listing_action_published" model="ir.actions.act_window">
        <field name="name">Published</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('approval_status', '=', 'published')]</field>
    </record>

    <record id="c21_property_listing_action_draft" model="ir.actions.act_window">
        <field name="name">Draft</field>
        <field name="res_model">c21.property.listing</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('approval_status', '=', 'draft')]</field>
    </record>

    <!-- Property Image Views (temporarily merged here) -->
    <record id="c21_property_image_view_form" model="ir.ui.view">
        <field name="name">c21.property.image.form</field>
        <field name="model">c21.property.image</field>
        <field name="arch" type="xml">
            <form string="Property Image">
                <sheet>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="name" placeholder="Image description..."/>
                            <field name="sequence"/>
                            <field name="is_cover"/>
                        </group>
                        <group>
                            <field name="image_url" placeholder="Paste image URL here to auto-download"
                                   help="Enter URL and save to automatically download the image"/>
                            <button name="action_download_from_url" type="object"
                                    string="Download from URL" class="btn-primary"
                                    invisible="not image_url"
                                    icon="fa-download"/>
                        </group>
                    </group>
                    <group>
                        <field name="image" widget="image" options="{'size': [0, 400]}"/>
                    </group>
                    <group string="Resized Versions (auto-generated)">
                        <label for="image_medium" string="Medium (512x512)"/>
                        <field name="image_medium" widget="image" options="{'size': [0, 200]}" nolabel="1"/>
                        <label for="image_small" string="Small (256x256)"/>
                        <field name="image_small" widget="image" options="{'size': [0, 100]}" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="c21_property_image_view_tree" model="ir.ui.view">
        <field name="name">c21.property.image.tree</field>
        <field name="model">c21.property.image</field>
        <field name="arch" type="xml">
            <list string="Property Images" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="is_cover"/>
                <field name="image_small" widget="image" options="{'size': [64, 64]}"/>
                <field name="name"/>
                <field name="property_id"/>
                <field name="image_url" optional="hide" placeholder="Paste URL to auto-download"/>
                <button name="action_download_from_url" type="object"
                        icon="fa-download" title="Download from URL"
                        invisible="not image_url"/>
            </list>
        </field>
    </record>

    <record id="c21_property_image_action" model="ir.actions.act_window">
        <field name="name">Property Images</field>
        <field name="res_model">c21.property.image</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
